FORGE_ENV=development
FORGE_ADDR=:3000
FORGE_BASE_URL=http://localhost:3000
FORGE_SECRET=replace-me-with-a-long-random-string
FORGE_COOKIE_NAME=forge_session
FORGE_SESSION_TTL=168h
FORGE_READ_TIMEOUT=15s
FORGE_WRITE_TIMEOUT=30s
FORGE_IDLE_TIMEOUT=60s
FORGE_SHUTDOWN_TIMEOUT=20s
FORGE_REQUEST_TIMEOUT=15s
FORGE_MAX_REQUEST_BODY_BYTES=1048576
FORGE_REPOS_ROOT=/data/repos
FORGE_DB_MAX_OPEN_CONNS=25
FORGE_DB_MAX_IDLE_CONNS=25
FORGE_DB_CONN_MAX_LIFETIME=1h
FORGE_DB_CONN_MAX_IDLE_TIME=15m
DATABASE_URL=postgres://forge:forge@localhost:5432/forge?sslmode=disable
REDIS_URL=redis://localhost:6379/0
